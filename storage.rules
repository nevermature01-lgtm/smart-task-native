rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /tasks/{taskId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /task_attachments/{taskId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /images/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}